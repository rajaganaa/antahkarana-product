# .env.example — Antahkarana MedAssist
# Copy to .env and fill in values
# Author: RAJAGANAPATHY M, SRM University

# ── Model Configuration ───────────────────────────────────────────────────────
MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=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                   # HuggingFace token (not needed for Qwen2.5)

# ── Engine Flags ──────────────────────────────────────────────────────────────
USE_VLLM=True                         # Set true on GCP L4 GPU
USE_BLIP2=True                        # Set true on GCP L4 GPU

# ── Vision Fallback (if BLIP-2 not available) ─────────────────────────────────
OPENAI_API_KEY=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                        # GPT-4o vision fallback (optional)

# ── RAG / ChromaDB ───────────────────────────────────────────────────────────
MEDASSIST_DATA_DIR=./data/drug_guides
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=medassist_drugs

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
UPLOAD_DIR=/tmp/antahkarana_uploads
