# .env.example — Antahkarana MedAssist
# Copy to .env and fill in values
# Author: RAJAGANAPATHY M, SRM University

# ── Model Configuration ───────────────────────────────────────────────────────
MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=                              # HuggingFace token (not needed for Qwen2.5)

# ── Engine Flags ──────────────────────────────────────────────────────────────
USE_VLLM=false                         # Set true on GCP L4 GPU
USE_BLIP2=false                        # Set true on GCP L4 GPU

# ── Vision Fallback (if BLIP-2 not available) ─────────────────────────────────
OPENAI_API_KEY=                        # GPT-4o vision fallback (optional)

# ── RAG / ChromaDB ───────────────────────────────────────────────────────────
MEDASSIST_DATA_DIR=./data/drug_guides
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=medassist_drugs

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
UPLOAD_DIR=/tmp/antahkarana_uploads
